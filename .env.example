# === Supabase ===
# Ambil dari: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Service role: HANYA untuk skrip admin/seed di server. JANGAN pernah diekspos ke browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# === Database (untuk Drizzle migrate/push) ===
# Supabase -> Project Settings -> Database -> Connection string (URI).
# Gunakan connection pooler (port 6543) untuk serverless/Netlify.
DATABASE_URL="postgresql://postgres.YOUR-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"
